# ============================================================
# App Finanzas - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- PRICE PROVIDER ---
# Options: "mock" (for testing, no external calls) | "yahoo" (free, real data)
# Start with "mock" to test the app without any API setup
PRICE_PROVIDER=mock

# --- TELEGRAM ALERTS ---
# To enable Telegram alerts:
# 1. Message @BotFather on Telegram, create a new bot, get the token
# 2. Start a chat with your bot, then get your chat_id from:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Leave these empty to disable Telegram (alerts still log to console)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- PORTFOLIO SETTINGS ---
# How much cash is currently available to invest (in EUR)
CASH_AVAILABLE_EUR=5000

# Minimum cash reserve to always keep (in EUR) - never deploy below this
TARGET_CASH_RESERVE_EUR=1000

# --- SCHEDULER ---
# Cron expression for when to run the daily engine
# Default: weekdays at 9:00 AM (market open time)
# Uses standard cron format: minute hour day month weekday
SCHEDULER_CRON=0 9 * * 1-5

# Timezone for the scheduler
SCHEDULER_TIMEZONE=Europe/Madrid

# --- ENGINE MODE ---
# Set to "true" to skip real price fetching and use mock data
MOCK_MODE=true

# --- DATA DIRECTORY ---
# Where to store JSON state files (relative to project root)
# Defaults to ./src/data if not set
DATA_DIR=./src/data

# --- ALERTS ---
# Minimum hours between repeat alerts for the same asset (prevents spam)
ALERT_COOLDOWN_HOURS=24

# Send daily digest even if no changes detected
ALWAYS_SEND_DIGEST=true

# --- NEXT.JS ---
# Only needed if deploying to a custom domain
# NEXTAUTH_URL=http://localhost:3000
